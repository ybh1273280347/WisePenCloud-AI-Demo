# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── 虚拟环境 ──────────────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── uv ────────────────────────────────────────────────────────────────────────
# lock 文件应提交，仅忽略 uv 自身缓存
.uv/

# ── 打包 / 分发 ───────────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── 环境变量 / 密钥（每个微服务各自的 .env 不提交）────────────────────────────
.env
.env.*
!.env.example

# ── 日志 ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── 操作系统 ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── 测试 / 覆盖率 ─────────────────────────────────────────────────────────────
